<Window x:Class="ParaAthleticsResults.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ParaAthleticsResults.ViewModels"
        xmlns:views="clr-namespace:ParaAthleticsResults.Views"
        Title="Para Athletics Results System"
        Height="900" Width="1600"
        MinHeight="768" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AthletesViewModel}">
            <views:AthletesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EventsViewModel}">
            <views:EventsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StartListViewModel}">
            <views:StartListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ResultsViewModel}">
            <views:ResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveResultsViewModel}">
            <views:LiveResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo Header -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                    <TextBlock Text="♿" FontSize="36" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Para Athletics" FontSize="16" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="Results System" FontSize="11"
                               Foreground="#90CAF9" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top">
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" Margin="0,0,10,0"/>
                            <TextBlock Text="Tableau de bord"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateEventsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏃" Margin="0,0,10,0"/>
                            <TextBlock Text="Épreuves"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateAthletesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Margin="0,0,10,0"/>
                            <TextBlock Text="Athlètes"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateStartListCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" Margin="0,0,10,0"/>
                            <TextBlock Text="Start List"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateResultsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏆" Margin="0,0,10,0"/>
                            <TextBlock Text="Résultats"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateLiveResultsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📡" Margin="0,0,10,0"/>
                            <TextBlock Text="Live Results"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateScoreboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🖥" Margin="0,0,10,0"/>
                            <TextBlock Text="Scoreboard"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateReportsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄" Margin="0,0,10,0"/>
                            <TextBlock Text="Rapports (PDF)"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Margin="0,0,10,0"/>
                            <TextBlock Text="Paramètres"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding NavigateUsersCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" Margin="0,0,10,0"/>
                            <TextBlock Text="Utilisateurs"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Language Toggle -->
                <StackPanel DockPanel.Dock="Bottom" Margin="16,0,16,8">
                    <TextBlock Text="Langue / اللغة" Foreground="#90CAF9" FontSize="11" Margin="8,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="8,0">
                        <Button Content="Français" Command="{Binding SetLanguageFrenchCommand}"
                                Style="{StaticResource SidebarButtonStyle}" Padding="12,6" FontSize="12"/>
                        <Button Content="العربية" Command="{Binding SetLanguageArabicCommand}"
                                Style="{StaticResource SidebarButtonStyle}" Padding="12,6" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- FinishLynx Status -->
                <Border DockPanel.Dock="Bottom" Margin="16,8,16,16" Padding="12" CornerRadius="8"
                        Background="#1E3A5F">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding IsFinishLynxConnected, Converter={x:Null}}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Foreground="White" FontSize="12">
                                <Run Text="FinishLynx: "/>
                                <Run Text="{Binding FinishLynxStatus}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource CardBrush}" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentDate}" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                        <TextBlock Text="{Binding CurrentTime}" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,24,0"/>
                        <ComboBox Width="300" SelectedItem="{Binding CompetitionName}"
                                  IsEditable="False" FontSize="14"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding CurrentUserName}"
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Border Grid.Row="1" Background="{StaticResource ContentBackgroundBrush}" Padding="16">
                <ContentControl Content="{Binding CurrentViewModel}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
